# TransitOps — Backend environment variables
# Copy this file to .env and fill in your values

# Server
PORT=3001

# MySQL 8
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=your_password_here
DB_NAME=transitops

# JWT — Dev B fills this in when auth is wired
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=8h
